@startuml
'https://plantuml.com/deployment-diagram

title Diagrama de Despliegue Rueditas Amigas

node "SistemaGeneradorDeRutas"
actor "Cliente"
cloud "Internet"
node "SistemaNotificacionProfesional"


rectangle  {
node "LoadBalancer"
node "Servidor1RueditasAmigas"
node "Servidor2RueditasAmigas"
database "BaseDeDatos"
database "BaseDeDatos2"
}

"LoadBalancer" -> "Servidor1RueditasAmigas"
"Servidor2RueditasAmigas" <-- "LoadBalancer"
"Servidor1RueditasAmigas" -r-> "BaseDeDatos"
"Servidor1RueditasAmigas" -l-> "BaseDeDatos2"
"Servidor2RueditasAmigas" -----> "BaseDeDatos"
"Servidor2RueditasAmigas" -up-> "BaseDeDatos2"
"Servidor1RueditasAmigas" -[bold]-> "SistemaNotificacionProfesional"
"Servidor2RueditasAmigas" --> "SistemaNotificacionProfesional"
"Servidor1RueditasAmigas" --> "SistemaGeneradorDeRutas"
"Servidor2RueditasAmigas" --> "SistemaGeneradorDeRutas"
"Cliente" --> "Internet"
"Internet" --> "LoadBalancer"


@enduml