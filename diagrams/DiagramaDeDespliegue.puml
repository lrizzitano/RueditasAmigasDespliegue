@startuml
'https://plantuml.com/deployment-diagram

title Diagrama de Despliegue Rueditas Amigas

node "SistemaGeneradorDeRutas"
actor "Cliente"
cloud "Internet"
node "SistemaNotificacionProfesional"


rectangle  {
node "LoadBalancer"
node "Servidor1RueditasAmigas"
node "Servidor2RueditasAmigas"
node "ServidorReservas"
database "BaseDeDatos"
database "BaseDeDatos2"
}

"LoadBalancer" --> "Servidor1RueditasAmigas" : HTTP
"LoadBalancer" --> "Servidor2RueditasAmigas" : HTTP
"Servidor1RueditasAmigas" --> "BaseDeDatos" : JDBC
"Servidor2RueditasAmigas" --> "BaseDeDatos" : JDBC
"Servidor1RueditasAmigas" --> "SistemaGeneradorDeRutas"
"Servidor2RueditasAmigas" --> "SistemaGeneradorDeRutas"
"Servidor1RueditasAmigas" --> "ServidorReservas"
"Servidor2RueditasAmigas" --> "ServidorReservas"
"Cliente" --> "Internet" : HTTPS
"ServidorReservas" --> "BaseDeDatos2": JDBC
"ServidorReservas" --> "SistemaNotificacionProfesional"  : HTTPS


@enduml
